<style>
    header {
        border-bottom: 1px solid var(--border);

        position: sticky;
        top: 0;

        background: var(--background);
        z-index: 10000;
    }

    nav {
        max-width: 1000px;
        margin: 0 auto;
        padding: 1rem 2rem;

        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    /* Your name */
    .logo {
        font-family: "Fraunces", serif;
        font-size: 1.4rem;
        font-weight: 600;
        color: var(--text);
    }

    /* Navigation links */
    .links {
        display: flex;
        gap: 1.5rem;
    }

    .links a {
        font-family: "Inter", sans-serif;
        color: var(--muted);
    }

    .links > a:not(.icon-link) {
        font-family: "Inter", sans-serif;
        color: var(--muted);
        text-decoration: none;
        position: relative;
        transition: color 0.2s ease;
    }

    .links > a:not(.icon-link)::after {
        content: "";

        position: absolute;
        left: 0;
        bottom: -5px;

        width: 100%;
        height: 2px;

        background: var(--accent);

        transform: scaleX(0);
        transform-origin: left;

        transition: transform 0.25s ease;
    }

    .links > a:not(.icon-link):hover {
        color: var(--accent);
    }

    .links > a:not(.icon-link):hover::after {
        transform: scaleX(1);
    }

    /* Optional: name hover */
    .logo:hover {
        color: var(--accent);
    }

    .icon-link svg {
        width: 1.2rem;
        height: 1.2rem;
    }

    .icon-link {
        color: var(--muted);
        display: flex;
        align-items: center;

        transition:
            color 0.2s ease,
            transform 0.2s ease;
    }

    .icon-link:hover {
        color: var(--accent);
        transform: translateY(-3px);
    }
</style>
